PORT=5000
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5174

# MongoDB Configuration
MONGO_URI=mongodb://<root_user>:<root_password>@localhost:27017/gencourse_ai?authSource=admin
MONGO_ROOT_USER=<root_user>
MONGO_ROOT_PASSWORD=<root_password>

# LLM Workers Configuration
# A JSON array defining the LLM workers to load. Registered workers are queried sequentially for slot availability.
# Supported providers: "gemini", "ollama", "cerebras".
LLM_WORKERS_CONFIG='[{"provider":"gemini","name":"GeminiPrimaryWorker","apiKey":"<your_gemini_api_key_here>","model":"gemini-3.1-flash-lite","maxConcurrency":3},{"provider":"cerebras","name":"CerebrasWorker","apiKey":"<your_cerebras_api_key_here>","model":"gpt-oss-120b","maxConcurrency":2},{"provider":"ollama","name":"OllamaWorker","baseUrl":"http://localhost:11434","model":"qwen2.5:1.5b-instruct","maxConcurrency":1}]'

# Auth0 Backend Session Config
SESSION_SECRET=<your_32_character_long_session_secret_key>
AUTH0_CLIENT_ID=<your_auth0_client_id_here>
AUTH0_ISSUER_BASE_URL=https://<your-auth0-tenant-domain>.auth0.com
JWT_SECRET=<your_jwt_secret_here>
