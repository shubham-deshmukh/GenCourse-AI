PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://<username>:<password>@localhost:27017/gencourse_ai?authSource=admin
GEMINI_API_KEY=<your_gemini_api_key>
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:1.5b-instruct

# Concurrency limit for parallel lesson content generation (default is 2)
CONCURRENT_GENERATION_LIMIT=2

# Auth0 Backend Session Config
SESSION_SECRET=<your_session_secret_32_chars>
BASE_URL=http://localhost:5174
AUTH0_CLIENT_ID=<your_auth0_client_id>
AUTH0_ISSUER_BASE_URL=https://<your_auth0_domain>.auth0.com

