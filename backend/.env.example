PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb://<username>:<password>@localhost:27017/gencourse_ai?authSource=admin
MONGO_ROOT_USER=<username>
MONGO_ROOT_PASSWORD=<password>

# Gemini API Configuration
GEMINI_API_KEY=<your_gemini_api_key_here>
GEMINI_MODEL=gemini-3.1-flash-lite

# Local Ollama Integration (Optional)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:1.5b-instruct

# Auth0 Backend Session Config
SESSION_SECRET=<your_32_character_long_session_secret_key>
FRONTEND_URL=http://localhost:5174
AUTH0_CLIENT_ID=<your_auth0_client_id_here>
AUTH0_CLIENT_SECRET=<your_auth0_client_secret_here>
AUTH0_ISSUER_BASE_URL=https://<your-auth0-domain>.auth0.com
JWT_SECRET=<your_jwt_secret_here>

# Concurrency limit for parallel lesson content generation (default is 2)
CONCURRENT_GENERATION_LIMIT=2

# Optional purpose overrides (e.g. uncomment/configure if needed)
OUTLINE_LLM_MODEL=gemini-3.1-flash-lite
LESSON_LLM_MODEL=gemini-3.1-flash-lite
CHAT_LLM_MODEL=gemini-3.1-flash-lite

